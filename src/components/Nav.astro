---
const base = import.meta.env.BASE_URL; // '/work/'
const links = [
  { href: `${base}#work`, label: 'Work' },
  { href: `${base}#business`, label: 'Business' },
  { href: `${base}#ai`, label: 'AI' },
  { href: `${base}#about`, label: 'About' },
];
---

<header
  class="fixed top-0 inset-x-0 z-50 transition-colors"
  style="backdrop-filter: blur(14px); background: color-mix(in oklab, var(--color-bg) 72%, transparent); border-bottom: 1px solid var(--color-border);"
>
  <nav class="mx-auto flex max-w-7xl items-center justify-between px-6 py-4">
    <a href={base} class="group flex items-center gap-2.5">
      <span
        class="grid h-8 w-8 place-items-center rounded-lg font-display text-sm font-bold text-black"
        style="background: linear-gradient(135deg, var(--color-brand), #7c5cfa);"
        >JM</span
      >
      <span class="font-display text-[15px] font-semibold tracking-tight text-ink">
        Jaylon Malone
      </span>
    </a>

    <div class="hidden items-center gap-1 md:flex">
      {
        links.map((l) => (
          <a
            href={l.href}
            class="rounded-full px-4 py-2 text-sm text-ink-soft transition-colors hover:text-ink"
          >
            {l.label}
          </a>
        ))
      }
      <a
        href={`${base}#contact`}
        class="ml-2 rounded-full px-4 py-2 text-sm font-medium text-black transition-transform hover:scale-[1.03]"
        style="background: linear-gradient(135deg, var(--color-brand), var(--color-brand-deep));"
      >
        Get in touch
      </a>
    </div>

    <a
      href={`${base}#contact`}
      class="rounded-full px-4 py-2 text-sm font-medium text-black md:hidden"
      style="background: var(--color-brand);"
    >
      Contact
    </a>
  </nav>
</header>
