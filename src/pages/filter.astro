---
import Base from '../layouts/Base.astro';
import { QUESTIONS, PATHS, WEIGHTS, RATING_LEGEND } from '../lib/filterData';
---

<Base
  title="AI Side Hustle Filter — Flash AI Solutions"
  description="5 questions. Find which AI income paths actually fit your situation. Honest ratings, no guru nonsense."
>
  <style is:global>
    :root { --accent: #7c5cfa; --accent-rgb: 124 92 250; }

    .opt-btn {
      width: 100%; text-align: left; display: block;
      padding: 0.9rem 1.125rem; min-height: 52px;
      border: 1px solid var(--color-border); border-radius: 0.75rem;
      background: var(--color-surface); color: var(--color-ink);
      font-family: var(--font-sans); font-size: 0.9375rem;
      cursor: pointer;
      transition: border-color 0.15s, box-shadow 0.15s, background 0.15s;
    }
    .opt-btn:hover {
      border-color: color-mix(in oklab, var(--accent) 45%, transparent);
      background: color-mix(in oklab, var(--accent) 6%, var(--color-surface));
    }
    .opt-btn.selected {
      border-color: var(--accent);
      background: color-mix(in oklab, var(--accent) 10%, var(--color-surface));
      box-shadow: 0 0 0 1px var(--accent),
                  0 0 22px -4px color-mix(in oklab, var(--accent) 35%, transparent);
    }
    .opt-btn:focus-visible { outline: 2px solid var(--accent); outline-offset: 2px; }

    .prog-track { height: 3px; background: var(--color-border); border-radius: 2px; overflow: hidden; }
    .prog-fill  { height: 100%; background: var(--accent); border-radius: 2px; transition: width 0.4s var(--ease-out-expo); }

    .rbar-track { height: 5px; background: var(--color-border); border-radius: 3px; overflow: hidden; }
    .rbar-fill  { height: 100%; border-radius: 3px; width: 0; transition: width 0.7s var(--ease-out-expo); }

    .path-card {
      border: 1px solid var(--color-border); border-radius: 1rem;
      background: var(--color-bg-1); padding: 1.375rem 1.5rem;
      margin-bottom: 1.25rem;
      transition: border-color 0.2s;
    }
    .path-card:hover { border-color: color-mix(in oklab, var(--accent) 38%, transparent); }

    .bs-badge {
      display: inline-flex; align-items: center; white-space: nowrap;
      padding: 0.225rem 0.7rem; border-radius: 999px;
      font-family: var(--font-mono); font-size: 0.72rem; font-weight: 500;
    }
    .bs-legit { background: color-mix(in oklab,#10b981 13%,transparent); color:#10b981; border:1px solid color-mix(in oklab,#10b981 28%,transparent); }
    .bs-mixed { background: color-mix(in oklab,#f59e0b 13%,transparent); color:#f59e0b; border:1px solid color-mix(in oklab,#f59e0b 28%,transparent); }
    .bs-hype  { background: color-mix(in oklab,#ef4444 13%,transparent); color:#ef4444; border:1px solid color-mix(in oklab,#ef4444 28%,transparent); }

    .skip-card {
      border: 1px solid color-mix(in oklab,#ef4444 22%,transparent);
      border-radius: 0.75rem;
      background: color-mix(in oklab,#ef4444 5%,var(--color-bg-1));
      padding: 1rem 1.25rem; margin-bottom: 0.75rem;
    }

    .btn-primary {
      display: inline-flex; align-items: center; justify-content: center; gap: 0.45rem;
      padding: 0.875rem 1.75rem; min-height: 48px;
      border-radius: 0.75rem; border: none;
      background: var(--accent); color: #fff;
      font-family: var(--font-display); font-size: 1rem; font-weight: 600;
      cursor: pointer; text-decoration: none;
      box-shadow: 0 0 24px -6px color-mix(in oklab, var(--accent) 50%, transparent);
      transition: opacity 0.15s, box-shadow 0.15s;
    }
    .btn-primary:hover  { opacity: 0.85; box-shadow: 0 0 36px -4px color-mix(in oklab,var(--accent) 65%,transparent); }
    .btn-primary:focus-visible { outline: 2px solid var(--accent); outline-offset: 3px; }
    .btn-primary:disabled { opacity: 0.38; cursor: not-allowed; }

    .btn-ghost {
      display: inline-flex; align-items: center; justify-content: center; gap: 0.4rem;
      padding: 0.75rem 1.375rem; min-height: 44px;
      border-radius: 0.75rem; border: 1px solid var(--color-border);
      background: transparent; color: var(--color-ink-soft);
      font-family: var(--font-sans); font-size: 0.9375rem; cursor: pointer;
      transition: border-color 0.15s, color 0.15s;
    }
    .btn-ghost:hover { border-color: var(--color-border-bright); color: var(--color-ink); }
    .btn-ghost:focus-visible { outline: 2px solid var(--accent); outline-offset: 2px; }

    .toast {
      position: fixed; bottom: 1.5rem; left: 50%;
      transform: translateX(-50%) translateY(16px);
      background: var(--color-bg-2); border: 1px solid var(--color-border);
      color: var(--color-ink); padding: 0.7rem 1.25rem;
      border-radius: 0.5rem; font-size: 0.875rem;
      opacity: 0; transition: opacity 0.2s, transform 0.2s;
      pointer-events: none; z-index: 200; white-space: nowrap;
    }
    .toast.show { opacity: 1; transform: translateX(-50%) translateY(0); }

    @media (prefers-reduced-motion: reduce) {
      .opt-btn, .path-card, .prog-fill, .rbar-fill, .toast,
      .btn-primary, .btn-ghost { transition: none !important; }
    }
  </style>

  <noscript>
    <div style="display:flex;flex-direction:column;align-items:center;justify-content:center;min-height:100vh;padding:2rem;text-align:center;gap:1.5rem;max-width:32rem;margin:0 auto;">
      <h1 style="font-family:'Space Grotesk',sans-serif;font-size:2rem;font-weight:700;color:#f4f4f8;line-height:1.1;">Most AI side hustles are garbage. Find the few that actually fit you.</h1>
      <p style="color:#b7b9c8;line-height:1.6;">This tool requires JavaScript to run the 5-question quiz. Get the full breakdown and starter playbook directly:</p>
      <a href="https://flashaisolutions.gumroad.com/l/vfwqjs" style="display:inline-block;padding:0.875rem 2rem;background:#7c5cfa;color:#fff;border-radius:0.75rem;font-weight:600;text-decoration:none;">Get the full breakdown</a>
    </div>
  </noscript>

  <div id="filter-app">

    <!-- INTRO -->
    <section id="s-intro" class="relative flex min-h-screen flex-col items-center justify-center overflow-hidden px-5 py-24 text-center">
      <div class="aura" style="width:580px;height:580px;left:-14%;top:-10%;--accent:#7c5cfa;opacity:0.42;"></div>
      <div class="aura" style="width:400px;height:400px;right:-10%;top:35%;--accent:#10b981;opacity:0.22;"></div>
      <div class="aura" style="width:460px;height:460px;left:28%;bottom:-18%;--accent:#7c5cfa;opacity:0.16;"></div>

      <div class="relative z-10 mx-auto w-full max-w-xl">
        <p class="mb-5 inline-flex items-center gap-2 rounded-full border px-4 py-1.5 text-xs tracking-wide hairline" style="background:var(--color-bg-1);color:var(--color-ink-soft);">
          <span style="display:inline-block;width:6px;height:6px;border-radius:50%;background:#7c5cfa;box-shadow:0 0 10px #7c5cfa;flex-shrink:0;"></span>
          Flash AI Solutions · Free tool
        </p>

        <h1 class="text-gradient font-display font-bold" style="font-size:clamp(2.2rem,8vw,4.5rem);line-height:1.03;letter-spacing:-0.025em;">
          Most AI side hustles are garbage.
        </h1>
        <p class="font-display font-bold" style="font-size:clamp(1.4rem,4vw,2.4rem);line-height:1.12;letter-spacing:-0.02em;margin-top:0.5rem;color:var(--color-ink);">
          Find the few that actually fit you.
        </p>

        <p class="mt-6 leading-relaxed" style="font-size:clamp(1rem,2.5vw,1.125rem);color:var(--color-ink-soft);max-width:32rem;margin-left:auto;margin-right:auto;">
          Honest ratings on every path. No guru playbook. Built for people who want a real answer, not a list of things that work for someone else.
        </p>
        <p class="mt-3 text-sm" style="color:var(--color-ink-mute);">5 questions. No email required to see your results.</p>

        <div class="mt-10">
          <button id="btn-start" class="btn-primary" style="font-size:1.0625rem;padding:1rem 2.5rem;">
            Start the filter
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </button>
        </div>

        <p class="mt-8 text-xs" style="color:var(--color-ink-faint);">
          Made by <a href={import.meta.env.BASE_URL} style="color:var(--color-ink-mute);text-decoration:underline;">Jaylon Malone / Flash AI Solutions</a>
        </p>
      </div>

      <div class="edge-fade-b" style="position:absolute;inset-x:0;bottom:0;height:200px;pointer-events:none;"></div>
    </section>

    <!-- QUIZ -->
    <section id="s-quiz" class="relative min-h-screen overflow-hidden px-5 py-16" hidden aria-live="polite" aria-atomic="false">
      <div class="aura" style="width:440px;height:440px;right:-8%;top:8%;--accent:#7c5cfa;opacity:0.28;"></div>

      <div class="relative z-10 mx-auto w-full max-w-xl pt-4">
        <div class="mb-10 flex items-center gap-4">
          <div class="prog-track flex-1">
            <div id="quiz-prog" class="prog-fill" style="width:0%;"></div>
          </div>
          <span id="quiz-num" class="shrink-0 font-mono text-sm" style="color:var(--color-ink-mute);">1 / 5</span>
        </div>

        <div id="quiz-body"></div>

        <div class="mt-8 flex items-center gap-3">
          <button id="btn-back" class="btn-ghost">
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M13 8H3M7 4L3 8l4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            Back
          </button>
          <button id="btn-next" class="btn-primary" style="flex:1;" disabled>
            Next
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </button>
        </div>
      </div>
    </section>

    <!-- RESULTS -->
    <section id="s-results" class="relative min-h-screen overflow-hidden px-5 py-16" hidden>
      <div class="aura" style="width:500px;height:500px;left:-12%;top:0%;--accent:#7c5cfa;opacity:0.3;"></div>
      <div class="aura" id="res-emerald" style="width:500px;height:500px;right:-10%;top:25%;--accent:#10b981;opacity:0;transition:opacity 0.9s ease;"></div>

      <div class="relative z-10 mx-auto w-full max-w-xl pt-4">
        <div id="results-body"></div>
      </div>
    </section>

  </div>

  <div id="toast" class="toast" role="status" aria-live="polite"></div>

  <script define:vars={{ QUESTIONS, PATHS, WEIGHTS, RATING_LEGEND }} is:inline>
    const GUMROAD_URL = 'https://flashaisolutions.gumroad.com/l/vfwqjs';

    let currentQ = 0;
    let answers = { time: null, budget: null, edge: [], speed: null, goal: null };
    let advTimer = null;

    const sIntro    = document.getElementById('s-intro');
    const sQuiz     = document.getElementById('s-quiz');
    const sResults  = document.getElementById('s-results');
    const quizBody  = document.getElementById('quiz-body');
    const progFill  = document.getElementById('quiz-prog');
    const quizNum   = document.getElementById('quiz-num');
    const btnBack   = document.getElementById('btn-back');
    const btnNext   = document.getElementById('btn-next');
    const toastEl   = document.getElementById('toast');
    const resEm     = document.getElementById('res-emerald');

    function showScreen(name) {
      [sIntro, sQuiz, sResults].forEach(s => s.setAttribute('hidden', ''));
      const t = name === 'intro' ? sIntro : name === 'quiz' ? sQuiz : sResults;
      t.removeAttribute('hidden');
      window.scrollTo({ top: 0, behavior: 'instant' });
      if (name === 'results' && resEm) {
        requestAnimationFrame(() => { resEm.style.opacity = '0.38'; });
      }
    }

    function esc(s) {
      return String(s)
        .replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;')
        .replace(/"/g, '&quot;').replace(/'/g, '&#39;');
    }

    function renderQuestion(idx) {
      const q = QUESTIONS[idx];
      const ans = answers[q.id];
      progFill.style.width = Math.round((idx / QUESTIONS.length) * 100) + '%';
      quizNum.textContent = (idx + 1) + ' / ' + QUESTIONS.length;

      const isLast = idx === QUESTIONS.length - 1;
      const arrowSvg = '<svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>';
      btnNext.innerHTML = esc(isLast ? 'See my results' : 'Next') + ' ' + arrowSvg;

      const rows = q.options.map(opt => {
        const sel = q.multi
          ? (Array.isArray(ans) && ans.indexOf(opt.value) !== -1)
          : ans === opt.value;
        const subH = opt.sub
          ? '<span style="display:block;font-size:0.8rem;margin-top:0.2rem;color:var(--color-ink-mute);">' + esc(opt.sub) + '</span>'
          : '';
        return '<button type="button" class="opt-btn' + (sel ? ' selected' : '') + '" data-val="' + esc(opt.value) + '">'
          + esc(opt.label) + subH + '</button>';
      }).join('');

      const hint = q.multi
        ? '<p style="font-size:0.8125rem;color:var(--color-ink-mute);margin-bottom:0.75rem;margin-top:-0.75rem;">Select all that apply. You can pick none.</p>'
        : '';

      quizBody.innerHTML =
        '<h2 style="font-family:var(--font-display);font-size:clamp(1.2rem,4vw,1.625rem);font-weight:700;letter-spacing:-0.02em;margin-bottom:1.375rem;color:var(--color-ink);line-height:1.18;">'
        + esc(q.prompt) + '</h2>' + hint
        + '<div style="display:flex;flex-direction:column;gap:0.625rem;">' + rows + '</div>';

      quizBody.querySelectorAll('.opt-btn').forEach(btn => {
        btn.addEventListener('click', () => {
          const val = btn.getAttribute('data-val');
          if (q.multi) {
            const arr = Array.isArray(answers[q.id]) ? answers[q.id].slice() : [];
            const i = arr.indexOf(val);
            if (i === -1) arr.push(val); else arr.splice(i, 1);
            answers[q.id] = arr;
            renderQuestion(currentQ);
            updateNav();
          } else {
            answers[q.id] = val;
            renderQuestion(currentQ);
            updateNav();
            clearTimeout(advTimer);
            advTimer = setTimeout(advance, 80);
          }
        });
      });

      updateNav();
    }

    function updateNav() {
      const q = QUESTIONS[currentQ];
      const val = answers[q.id];
      btnNext.disabled = q.multi ? false : val === null;
    }

    function advance() {
      const q = QUESTIONS[currentQ];
      if (!q.multi && answers[q.id] === null) return;
      if (currentQ < QUESTIONS.length - 1) {
        currentQ++;
        renderQuestion(currentQ);
      } else {
        showScreen('results');
        renderResults();
      }
    }

    function scoreOf(path) {
      let s = 0;
      if (answers.time   && path.timeFit.indexOf(answers.time) !== -1)   s += WEIGHTS.time;
      if (answers.budget && path.budgetFit.indexOf(answers.budget) !== -1) s += WEIGHTS.budget;
      const edgeArr = Array.isArray(answers.edge) ? answers.edge : [];
      s += WEIGHTS.edgePerMatch * edgeArr.filter(e => path.edgeFit.indexOf(e) !== -1).length;
      if (answers.speed  && path.speedFit.indexOf(answers.speed) !== -1)  s += WEIGHTS.speed;
      if (answers.goal   && path.goalFit.indexOf(answers.goal) !== -1)    s += WEIGHTS.goal;
      return s;
    }

    function getRanked() {
      return PATHS
        .map(p => ({ path: p, score: scoreOf(p) }))
        .sort((a, b) => {
          if (b.score !== a.score) return b.score - a.score;
          if (a.path.bsFactor !== b.path.bsFactor) return a.path.bsFactor - b.path.bsFactor;
          return a.path.difficulty - b.path.difficulty;
        });
    }

    function bsCls(bf) { return bf <= 2 ? 'bs-legit' : bf === 3 ? 'bs-mixed' : 'bs-hype'; }
    function bsLbl(bf) { return bf <= 2 ? 'Legit'    : bf === 3 ? 'Mixed'    : 'High hype'; }
    function bsCol(bf) { return bf <= 2 ? '#10b981'  : bf === 3 ? '#f59e0b'  : '#ef4444'; }

    function ratingBar(key, val) {
      const pct = (val / 5) * 100;
      const col = key === 'bsFactor' ? bsCol(val) : '#7c5cfa';
      const lbl = { difficulty:'Difficulty', startupCost:'Startup cost', timeToFirstDollar:'Time to first $', bsFactor:'BS factor' }[key] || key;
      const tip = (RATING_LEGEND[key] && RATING_LEGEND[key][val]) ? esc(RATING_LEGEND[key][val]) : '';
      return '<div style="margin-bottom:0.625rem;">'
        + '<div style="display:flex;justify-content:space-between;align-items:baseline;margin-bottom:0.28rem;">'
          + '<span style="font-size:0.72rem;color:var(--color-ink-mute);text-transform:uppercase;letter-spacing:0.07em;">' + esc(lbl) + '</span>'
          + '<span style="font-size:0.72rem;font-family:var(--font-mono);color:var(--color-ink-soft);"' + (tip ? ' title="' + tip + '"' : '') + '>'
            + val + '/5' + (tip ? ' · ' + tip : '') + '</span>'
        + '</div>'
        + '<div class="rbar-track"><div class="rbar-fill" data-pct="' + pct + '" style="background:' + col + ';"></div></div>'
      + '</div>';
    }

    function pathCard(item, rank) {
      const p = item.path;
      const rnkLbl = ['#1 Match', '#2 Match', '#3 Match'][rank] || '';
      const rnkCol = ['#7c5cfa', '#b7b9c8', '#767889'][rank] || '#767889';
      return '<div class="path-card reveal">'
        + '<div style="display:flex;justify-content:space-between;align-items:flex-start;gap:1rem;flex-wrap:wrap;margin-bottom:1rem;">'
          + '<div>'
            + '<p style="font-size:0.72rem;font-family:var(--font-mono);color:' + rnkCol + ';margin-bottom:0.3rem;">' + esc(rnkLbl) + '</p>'
            + '<h3 style="font-family:var(--font-display);font-size:1.1rem;font-weight:700;letter-spacing:-0.01em;color:var(--color-ink);">' + esc(p.name) + '</h3>'
          + '</div>'
          + '<span class="bs-badge ' + bsCls(p.bsFactor) + '">' + esc(bsLbl(p.bsFactor)) + '</span>'
        + '</div>'
        + '<p style="font-size:0.9rem;color:var(--color-ink-soft);line-height:1.55;margin-bottom:1.25rem;">' + esc(p.blurb) + '</p>'
        + '<div style="margin-bottom:1.125rem;">'
          + ratingBar('difficulty', p.difficulty)
          + ratingBar('startupCost', p.startupCost)
          + ratingBar('timeToFirstDollar', p.timeToFirstDollar)
          + ratingBar('bsFactor', p.bsFactor)
        + '</div>'
        + '<div style="border-top:1px solid var(--color-border);padding-top:1rem;display:flex;flex-direction:column;gap:0.875rem;">'
          + '<div><p style="font-size:0.68rem;text-transform:uppercase;letter-spacing:0.08em;color:var(--color-ink-mute);margin-bottom:0.3rem;">Best for</p>'
            + '<p style="font-size:0.875rem;color:var(--color-ink-soft);">' + esc(p.bestFor) + '</p></div>'
          + '<div style="background:color-mix(in oklab,#ef4444 7%,var(--color-bg));border:1px solid color-mix(in oklab,#ef4444 22%,transparent);border-radius:0.5rem;padding:0.75rem 1rem;">'
            + '<p style="font-size:0.68rem;text-transform:uppercase;letter-spacing:0.08em;color:#ef4444;margin-bottom:0.3rem;">The catch</p>'
            + '<p style="font-size:0.875rem;color:var(--color-ink-soft);line-height:1.5;">' + esc(p.realTalk) + '</p>'
          + '</div>'
          + '<div style="background:color-mix(in oklab,#10b981 7%,var(--color-bg));border:1px solid color-mix(in oklab,#10b981 22%,transparent);border-radius:0.5rem;padding:0.75rem 1rem;">'
            + '<p style="font-size:0.68rem;text-transform:uppercase;letter-spacing:0.08em;color:#10b981;margin-bottom:0.3rem;">Start here</p>'
            + '<p style="font-size:0.875rem;color:var(--color-ink-soft);line-height:1.5;">' + esc(p.firstStep) + '</p>'
          + '</div>'
        + '</div>'
      + '</div>';
    }

    function profileLine() {
      const tMap = { lt5:'under 5h/week', '5to15':'5 to 15h/week', '15to30':'15 to 30h/week', '30plus':'30+ hours/week' };
      const gMap = { cash:'wants fast cash', asset:'building an asset', replace:'replacing job income', learn:'learning the space' };
      const edges = (Array.isArray(answers.edge) ? answers.edge : []).filter(e => e !== 'cold');
      const edgeStr = edges.length ? edges.join(' + ') : 'starting cold';
      return [tMap[answers.time], edgeStr, gMap[answers.goal]].filter(Boolean).join(' · ');
    }

    function renderResults() {
      const ranked = getRanked();
      const top3 = ranked.slice(0, 3);
      const top3ids = {};
      top3.forEach(r => { top3ids[r.path.id] = true; });

      const skip = ranked
        .filter(r => r.path.hype && !top3ids[r.path.id])
        .sort((a, b) => a.score - b.score)
        .slice(0, 2);

      const cardsHtml = top3.map((item, i) => pathCard(item, i)).join('');

      const skipHtml = skip.length
        ? '<div style="margin-top:3rem;" class="reveal">'
            + '<h3 style="font-family:var(--font-display);font-size:1.1rem;font-weight:700;color:var(--color-ink);margin-bottom:0.4rem;">Skip these (for your situation)</h3>'
            + '<p style="font-size:0.875rem;color:var(--color-ink-mute);margin-bottom:1.125rem;line-height:1.5;">You will see these pushed everywhere. Here is why they are a trap for you right now.</p>'
            + skip.map(item =>
                '<div class="skip-card">'
                + '<p style="font-weight:600;font-size:0.9375rem;color:var(--color-ink);margin-bottom:0.35rem;">' + esc(item.path.name) + '</p>'
                + '<p style="font-size:0.875rem;color:var(--color-ink-soft);line-height:1.5;">' + esc(item.path.realTalk) + '</p>'
              + '</div>').join('')
          + '</div>'
        : '';

      const ctaHtml = '<div class="reveal" style="margin-top:3rem;border:1px solid color-mix(in oklab,#7c5cfa 35%,transparent);border-radius:1rem;background:color-mix(in oklab,#7c5cfa 8%,var(--color-bg-1));padding:1.75rem;text-align:center;">'
        + '<h3 style="font-family:var(--font-display);font-size:1.2rem;font-weight:700;color:var(--color-ink);margin-bottom:0.4rem;">Get the full breakdown + starter playbook</h3>'
        + '<p style="font-size:0.875rem;color:var(--color-ink-soft);margin-bottom:1.5rem;line-height:1.55;">Deeper analysis on every path, real first steps, and what to build in month one.</p>'
        + '<div style="display:flex;flex-direction:column;gap:0.75rem;">'
          + '<a href="' + esc(GUMROAD_URL) + '" target="_blank" rel="noopener noreferrer" class="btn-primary" style="width:100%;justify-content:center;">Get the playbook</a>'
          + '<div style="display:flex;gap:0.625rem;">'
            + '<button id="btn-share"   class="btn-ghost" style="flex:1;">Share results</button>'
            + '<button id="btn-restart" class="btn-ghost" style="flex:1;">Start over</button>'
          + '</div>'
        + '</div>'
      + '</div>';

      const rb = document.getElementById('results-body');
      rb.innerHTML =
        '<p style="font-size:0.75rem;text-transform:uppercase;letter-spacing:0.1em;color:var(--color-ink-mute);margin-bottom:0.4rem;">Your results</p>'
        + '<h2 style="font-family:var(--font-display);font-size:clamp(1.75rem,6vw,2.5rem);font-weight:700;letter-spacing:-0.025em;color:var(--color-ink);margin-bottom:0.45rem;">Your top matches</h2>'
        + '<p style="font-size:0.875rem;color:var(--color-ink-mute);margin-bottom:2.25rem;line-height:1.5;">' + esc(profileLine()) + '</p>'
        + cardsHtml + skipHtml + ctaHtml;

      requestAnimationFrame(() => {
        requestAnimationFrame(() => {
          rb.querySelectorAll('.rbar-fill').forEach(el => {
            el.style.width = el.getAttribute('data-pct') + '%';
          });
          rb.querySelectorAll('.reveal').forEach(el => el.classList.add('in'));
        });
      });

      document.getElementById('btn-share').addEventListener('click', shareResults);
      document.getElementById('btn-restart').addEventListener('click', restart);
    }

    function shareResults() {
      const url = window.location.href.split('?')[0];
      const msg = 'I just filtered the AI side hustles actually worth doing. 5 questions, honest ratings: ' + url;
      if (navigator.share) {
        navigator.share({ title: 'AI Side Hustle Filter', text: msg, url }).catch(() => {});
      } else {
        navigator.clipboard.writeText(msg)
          .then(() => showToast('Link copied to clipboard.'))
          .catch(() => showToast('Copy failed. Share the page URL manually.'));
      }
    }

    function restart() {
      currentQ = 0;
      answers = { time: null, budget: null, edge: [], speed: null, goal: null };
      if (resEm) resEm.style.opacity = '0';
      renderQuestion(0);
      showScreen('quiz');
    }

    function showToast(msg) {
      toastEl.textContent = msg;
      toastEl.classList.add('show');
      setTimeout(() => toastEl.classList.remove('show'), 2800);
    }

    document.getElementById('btn-start').addEventListener('click', () => {
      currentQ = 0;
      answers = { time: null, budget: null, edge: [], speed: null, goal: null };
      renderQuestion(0);
      showScreen('quiz');
    });

    btnBack.addEventListener('click', () => {
      if (currentQ === 0) { showScreen('intro'); return; }
      currentQ--;
      renderQuestion(currentQ);
    });

    btnNext.addEventListener('click', advance);
  </script>
</Base>
