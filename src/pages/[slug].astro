---
import { getCollection, render } from 'astro:content';
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import { CATEGORY } from '../lib/categories';

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects.map((project) => ({
    params: { slug: project.id },
    props: { project },
  }));
}

const base = import.meta.env.BASE_URL; // '/work/'
const { project } = Astro.props;
const d = project.data;
const c = CATEGORY[d.category];
const { Content } = await render(project);
---

<Base title={`${d.title} — Jaylon Malone`} description={d.tagline}>
  <Nav />
  <main style={`--accent:${c.accent}; --accent-rgb:${c.rgb};`}>
    <!-- header -->
    <section class="relative overflow-hidden pt-36 pb-12 md:pt-44">
      <div class="aura left-[-5%] top-[-10%] h-[480px] w-[480px]"></div>
      <div class="relative mx-auto max-w-4xl px-6">
        <a href={`${base}#work`} class="mb-8 inline-flex items-center gap-1.5 text-sm text-ink-mute transition-colors hover:text-ink">
          ← All work
        </a>
        <div class="flex flex-wrap items-center gap-3">
          <span class="text-xs font-semibold uppercase tracking-[0.16em]" style="color: var(--accent);">{c.label}</span>
          <span class="rounded-full px-2.5 py-0.5 text-[11px]"
                style="background: var(--color-bg-1); color: var(--accent); border:1px solid color-mix(in oklab, var(--accent) 40%, transparent);">{d.status}</span>
          {d.private && <span class="text-[11px] uppercase tracking-wider text-ink-faint">Private repo</span>}
        </div>
        <h1 class="mt-5 font-display text-4xl font-bold leading-[1.02] text-ink md:text-6xl">{d.title}</h1>
        <p class="mt-5 max-w-2xl text-lg leading-relaxed text-ink-soft">{d.tagline}</p>

        <div class="mt-8 flex flex-wrap gap-x-10 gap-y-4 border-y py-5 hairline">
          <div><div class="text-[11px] uppercase tracking-wider text-ink-faint">Role</div><div class="mt-1 text-sm text-ink">{d.role}</div></div>
          <div><div class="text-[11px] uppercase tracking-wider text-ink-faint">Year</div><div class="mt-1 text-sm text-ink">{d.year}</div></div>
          <div class="min-w-[40%] flex-1">
            <div class="text-[11px] uppercase tracking-wider text-ink-faint">Stack</div>
            <div class="mt-1.5 flex flex-wrap gap-1.5">
              {d.stack.map((s) => (
                <span class="rounded-md px-2 py-0.5 text-[12px] text-ink-soft" style="background: var(--color-bg-1); border:1px solid var(--color-border);">{s}</span>
              ))}
            </div>
          </div>
        </div>

        {(d.links.live || d.links.repo) && (
          <div class="mt-6 flex flex-wrap gap-3">
            {d.links.live && (
              <a href={d.links.live} class="rounded-full px-5 py-2.5 text-sm font-semibold text-black"
                 style="background: var(--accent);">Live site ↗</a>
            )}
            {d.links.repo && (
              <a href={d.links.repo} class="rounded-full border px-5 py-2.5 text-sm font-medium text-ink hairline"
                 style="background: var(--color-bg-1);">View repo ↗</a>
            )}
          </div>
        )}
      </div>
    </section>

    <!-- cover band -->
    <div class="mx-auto max-w-4xl px-6">
      <div class={`relative overflow-hidden rounded-2xl ${d.cover ? '' : 'h-48 md:h-64'}`}
           style="background:
             radial-gradient(110% 130% at 15% 10%, color-mix(in oklab, var(--accent) 38%, transparent), transparent 55%),
             radial-gradient(120% 120% at 90% 100%, color-mix(in oklab, var(--accent) 20%, transparent), transparent 55%),
             linear-gradient(155deg, var(--color-bg-2), var(--color-bg)); border:1px solid var(--color-border);">
        {d.cover ? (
          <img src={base + d.cover.replace(/^\//, '')} alt={`${d.title} screenshot`} loading="lazy" decoding="async"
               class="block w-full" />
        ) : (
          <>
            <div class="absolute inset-0 opacity-[0.07]"
                 style="background-image: linear-gradient(var(--accent) 1px, transparent 1px), linear-gradient(90deg, var(--accent) 1px, transparent 1px); background-size: 40px 40px;"></div>
            <span class="absolute bottom-5 right-6 text-xs text-ink-faint">Screenshots coming soon</span>
          </>
        )}
      </div>
    </div>

    <!-- highlights + body -->
    <article class="mx-auto max-w-4xl px-6 py-12">
      {d.highlights.length > 0 && (
        <ul class="mb-10 grid gap-3 sm:grid-cols-2">
          {d.highlights.map((h) => (
            <li class="flex gap-3 rounded-xl border p-4 hairline" style="background: var(--color-bg-1);">
              <span class="mt-1.5 h-1.5 w-1.5 shrink-0 rounded-full" style="background: var(--accent);"></span>
              <span class="text-sm leading-relaxed text-ink-soft">{h}</span>
            </li>
          ))}
        </ul>
      )}
      <div class="prose-flash">
        <Content />
      </div>
    </article>
  </main>
  <Footer />
</Base>

<style is:global>
  .prose-flash { color: var(--color-ink-soft); line-height: 1.75; }
  .prose-flash > * + * { margin-top: 1.1rem; }
  .prose-flash h2 {
    font-family: var(--font-display);
    color: var(--color-ink);
    font-size: 1.6rem;
    font-weight: 700;
    margin-top: 2.4rem;
    letter-spacing: -0.02em;
  }
  .prose-flash h3 { color: var(--color-ink); font-size: 1.2rem; font-weight: 600; margin-top: 1.8rem; }
  .prose-flash strong { color: var(--color-ink); font-weight: 600; }
  .prose-flash a { color: var(--accent); text-decoration: underline; text-underline-offset: 3px; }
  .prose-flash ul { list-style: none; padding: 0; }
  .prose-flash li { position: relative; padding-left: 1.4rem; margin-top: 0.5rem; }
  .prose-flash li::before {
    content: ''; position: absolute; left: 0; top: 0.65em;
    height: 6px; width: 6px; border-radius: 50%; background: var(--accent);
  }
  .prose-flash blockquote {
    border-left: 2px solid var(--accent);
    padding: 0.4rem 0 0.4rem 1.2rem;
    color: var(--color-ink-mute);
    font-style: italic;
  }
  .prose-flash code {
    font-family: var(--font-mono);
    font-size: 0.85em;
    background: var(--color-bg-2);
    padding: 0.15em 0.4em;
    border-radius: 4px;
  }
</style>
