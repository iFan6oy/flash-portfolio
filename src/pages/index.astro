---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import ProjectCard from '../components/ProjectCard.astro';
import { GROUPS } from '../lib/categories';

const base = import.meta.env.BASE_URL; // '/work/'
const asset = (p: string) => base + p.replace(/^\//, '');
const all = await getCollection('projects');
const byOrder = (a: any, b: any) => a.data.order - b.data.order;

const hub = all.find((p) => p.id === 'flash-media-hub')!;
const featured = all
  .filter((p) => p.data.featured && p.id !== 'flash-media-hub')
  .sort(byOrder);
const business = all.filter((p) => p.data.group === 'business').sort(byOrder);
const ai = all.filter((p) => p.data.group === 'ai').sort(byOrder);
const experiments = all.filter((p) => p.data.group === 'experiments').sort(byOrder);

const skills = [
  { label: 'AI / LLM', items: ['Claude API', 'Multi-Agent Debate', 'Agent Orchestration', 'Prompt Engineering', 'RAG'] },
  { label: 'Languages', items: ['TypeScript / JS', 'Python', 'C#', 'Rust (Anchor)', 'SQL'] },
  { label: 'Web / Frontend', items: ['Astro', 'Next.js 16', 'SvelteKit', 'React', 'Tailwind 4', 'WebGPU'] },
  { label: 'Mobile', items: ['React Native', 'Expo', 'Reanimated', 'Electron'] },
  { label: 'Backend / Data', items: ['Node / Express', 'Hono / tRPC', 'Prisma / Drizzle', 'PostgreSQL', 'SQLite'] },
  { label: 'Cloud / Infra', items: ['Hetzner VPS', 'PM2', 'Nginx', 'Vercel', 'Supabase', 'WorkOS'] },
  { label: 'Power Platform', items: ['Power Apps', 'Power Automate', 'SharePoint', 'Dataverse', 'Power BI'] },
  { label: 'Web3', items: ['Solana / web3.js', 'Jupiter', 'SPL Tokens', 'ethers'] },
];
---

<Base>
  <Nav />
  <main>
    <!-- ===================== HERO ===================== -->
    <section class="relative overflow-hidden pt-40 pb-24 md:pt-52 md:pb-32">
      <div class="aura left-[-10%] top-[-5%] h-[520px] w-[520px]" style="--accent:#00d4ff;"></div>
      <div class="aura right-[-8%] top-[20%] h-[460px] w-[460px]" style="--accent:#7c5cfa; opacity:.35;"></div>
      <div class="aura left-[30%] bottom-[-15%] h-[420px] w-[420px]" style="--accent:#10b981; opacity:.22;"></div>

      <div class="relative mx-auto max-w-7xl px-6">
        <p class="mb-6 inline-flex items-center gap-2 rounded-full border px-4 py-1.5 text-xs tracking-wide text-ink-soft hairline"
           style="background: var(--color-bg-1);">
          <span class="h-1.5 w-1.5 rounded-full" style="background:#22c55e; box-shadow:0 0 10px #22c55e;"></span>
          Mobile, AL · Founder of Flash AI Solutions · Available for work
        </p>

        <h1 class="max-w-5xl font-display text-[clamp(2.6rem,7vw,5.6rem)] font-bold leading-[0.98] text-ink">
          I build AI-powered products,
          <span class="text-gradient">autonomous systems</span>,
          and the enterprise workflows underneath them.
        </h1>

        <p class="mt-8 max-w-2xl text-lg leading-relaxed text-ink-soft">
          Software developer and solutions architect. I&apos;ve shipped a workflow system
          used by <span class="text-ink">7,200 staff</span>, an autonomous trading engine
          that moves real money, and a self-built media OS that runs my day. I take
          products from architecture to production, and own the result.
        </p>

        <div class="mt-10 flex flex-wrap items-center gap-4">
          <a href="#work"
             class="rounded-full px-6 py-3 text-sm font-semibold text-black transition-transform hover:scale-[1.03]"
             style="background: linear-gradient(135deg, var(--color-brand), var(--color-brand-deep)); box-shadow: 0 12px 40px -8px rgba(0,212,255,.4);">
            View the work
          </a>
          <a href={asset('JaylonMalone_Resume.pdf')}
             class="rounded-full border px-6 py-3 text-sm font-medium text-ink transition-colors hover:border-[var(--color-border-bright)] hairline"
             style="background: var(--color-bg-1);">
            Download resume
          </a>
        </div>

        <!-- proof strip -->
        <div class="mt-16 grid grid-cols-2 gap-x-8 gap-y-6 sm:grid-cols-4 max-w-3xl">
          {[
            { n: '7,200', l: 'staff on a system I built' },
            { n: '92', l: 'schools in production' },
            { n: '6', l: 'live products & services' },
            { n: '3', l: 'runtimes for one media OS' },
          ].map((s) => (
            <div>
              <div class="font-display text-3xl font-bold text-ink">{s.n}</div>
              <div class="mt-1 text-xs leading-snug text-ink-mute">{s.l}</div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ===================== FEATURED ===================== -->
    <section id="work" class="relative mx-auto max-w-7xl scroll-mt-24 px-6 py-16">
      <div class="reveal mb-10">
        <p class="text-xs font-semibold uppercase tracking-[0.2em] text-brand">Selected work</p>
        <h2 class="mt-3 font-display text-4xl font-bold text-ink md:text-5xl">Featured projects</h2>
      </div>

      <!-- Flagship spotlight: the hub -->
      <a href={`${base}${hub.id}/`}
         class="reveal group relative mb-8 grid overflow-hidden rounded-3xl md:grid-cols-2"
         style="--accent:#ff6b35; border:1px solid var(--color-border); background: var(--color-bg-1);">
        <div class="relative min-h-[280px] overflow-hidden"
             style="background:
               radial-gradient(110% 110% at 20% 15%, color-mix(in oklab, var(--accent) 42%, transparent), transparent 55%),
               radial-gradient(120% 120% at 85% 95%, color-mix(in oklab, #00d4ff 30%, transparent), transparent 55%),
               linear-gradient(150deg, var(--color-bg-2), var(--color-bg));">
          <img src={asset(hub.data.cover)} alt="Flash Media Hub screenshot" loading="lazy" decoding="async"
               class="absolute inset-0 h-full w-full object-cover object-left-top transition-transform duration-700 group-hover:scale-[1.03]" />
          <div class="absolute inset-0"
               style="background: linear-gradient(110deg, transparent 50%, color-mix(in oklab, var(--color-bg-1) 94%, transparent)); box-shadow: inset 0 0 80px color-mix(in oklab, var(--accent) 16%, transparent);"></div>
        </div>
        <div class="flex flex-col justify-center gap-4 p-8 md:p-12">
          <div class="flex items-center gap-3">
            <span class="text-xs font-semibold uppercase tracking-[0.16em]" style="color: var(--accent);">Flagship · Media OS</span>
            <span class="rounded-full px-2.5 py-0.5 text-[11px]" style="background: var(--color-bg-2); color: var(--accent); border:1px solid color-mix(in oklab, var(--accent) 40%, transparent);">Active</span>
          </div>
          <h3 class="font-display text-3xl font-bold text-ink md:text-4xl">{hub.data.title}</h3>
          <p class="text-base leading-relaxed text-ink-soft">{hub.data.tagline}</p>
          <ul class="mt-1 space-y-1.5">
            {hub.data.highlights.map((h) => (
              <li class="flex gap-2.5 text-sm text-ink-soft">
                <span class="mt-1.5 h-1 w-1 shrink-0 rounded-full" style="background: var(--accent);"></span>{h}
              </li>
            ))}
          </ul>
          <span class="mt-2 inline-flex items-center gap-1.5 text-sm font-medium" style="color: var(--accent);">
            Read the case study →
          </span>
        </div>
      </a>

      <!-- featured grid -->
      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-2">
        {featured.map((p) => (
          <div class="reveal">
            <ProjectCard slug={p.id} title={p.data.title} tagline={p.data.tagline}
              category={p.data.category} status={p.data.status} stack={p.data.stack}
              isPrivate={p.data.private} cover={p.data.cover} large />
          </div>
        ))}
      </div>
    </section>

    <!-- ===================== GROUPED SECTIONS ===================== -->
    {[
      { id: 'business', meta: GROUPS.business, items: business },
      { id: 'ai', meta: GROUPS.ai, items: ai },
      { id: 'experiments', meta: GROUPS.experiments, items: experiments },
    ].map((sec) => (
      <section id={sec.id} class="mx-auto max-w-7xl scroll-mt-24 px-6 py-16">
        <div class="reveal mb-10 max-w-2xl">
          <p class="text-xs font-semibold uppercase tracking-[0.2em] text-brand">{sec.meta.kicker}</p>
          <h2 class="mt-3 font-display text-3xl font-bold text-ink md:text-4xl">{sec.meta.title}</h2>
          <p class="mt-3 text-ink-soft">{sec.meta.blurb}</p>
        </div>
        <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
          {sec.items.map((p) => (
            <div class="reveal">
              <ProjectCard slug={p.id} title={p.data.title} tagline={p.data.tagline}
                category={p.data.category} status={p.data.status} stack={p.data.stack}
                isPrivate={p.data.private} cover={p.data.cover} />
            </div>
          ))}
        </div>
      </section>
    ))}

    <!-- ===================== ABOUT + SKILLS ===================== -->
    <section id="about" class="relative scroll-mt-24 overflow-hidden py-24">
      <div class="aura right-[-10%] top-[10%] h-[480px] w-[480px]" style="--accent:#7c5cfa; opacity:.2;"></div>
      <div class="relative mx-auto grid max-w-7xl gap-16 px-6 lg:grid-cols-[1.1fr_1fr]">
        <div class="reveal">
          <p class="text-xs font-semibold uppercase tracking-[0.2em] text-brand">About</p>
          <h2 class="mt-3 font-display text-3xl font-bold text-ink md:text-4xl">
            From a 92-school district system to shipping my own products.
          </h2>
          <div class="mt-6 space-y-4 text-ink-soft leading-relaxed">
            <p>
              I&apos;m Jaylon Malone, a software developer based in Mobile, Alabama. I hold a
              BS in Computer Science from the University of South Alabama and spent three
              years as an Application Developer at Mobile County Public Schools, where I
              architected a travel-reimbursement and voucher platform used across 92
              schools by 7,200 staff.
            </p>
            <p>
              In January 2026 I went full-time on <strong class="text-ink">Flash AI
              Solutions</strong>, my own company, to build AI-powered products and
              automation for businesses. I work across the stack, from Power Platform and
              enterprise SaaS to autonomous agents, trading systems, and native apps, and
              I care about systems that actually ship and stay running.
            </p>
            <p>
              I build with a bias for the modern best-in-class tool, real data over vanity
              metrics, and grounded, cost-aware AI over demos.
            </p>
          </div>
        </div>

        <div class="reveal">
          <p class="mb-5 text-xs font-semibold uppercase tracking-[0.2em] text-brand">Stack</p>
          <div class="space-y-5">
            {skills.map((g) => (
              <div>
                <p class="mb-2 text-sm font-medium text-ink">{g.label}</p>
                <div class="flex flex-wrap gap-2">
                  {g.items.map((s) => (
                    <span class="rounded-md px-2.5 py-1 text-[12px] text-ink-soft"
                          style="background: var(--color-bg-1); border:1px solid var(--color-border);">{s}</span>
                  ))}
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

    <!-- ===================== CONTACT ===================== -->
    <section id="contact" class="relative scroll-mt-24 px-6 py-24">
      <div class="relative mx-auto max-w-4xl overflow-hidden rounded-3xl border p-10 text-center md:p-16 hairline"
           style="background: radial-gradient(120% 140% at 50% 0%, color-mix(in oklab, var(--color-brand) 14%, transparent), transparent 60%), var(--color-bg-1);">
        <div class="aura left-1/2 top-[-30%] h-[360px] w-[360px] -translate-x-1/2" style="--accent:#00d4ff; opacity:.3;"></div>
        <div class="relative">
          <h2 class="font-display text-3xl font-bold text-ink md:text-5xl">Let&apos;s build something.</h2>
          <p class="mx-auto mt-4 max-w-xl text-ink-soft">
            Open to consulting work and engineering roles. Tell me what you&apos;re trying to
            ship and I&apos;ll tell you the fastest real path to it.
          </p>
          <div class="mt-8 flex flex-wrap justify-center gap-4">
            <a href="mailto:jaylon@flashaisolutions.org"
               class="rounded-full px-6 py-3 text-sm font-semibold text-black transition-transform hover:scale-[1.03]"
               style="background: linear-gradient(135deg, var(--color-brand), var(--color-brand-deep));">
              Email me
            </a>
            <a href="https://github.com/iFan6oy"
               class="rounded-full border px-6 py-3 text-sm font-medium text-ink hairline"
               style="background: var(--color-bg-2);">GitHub</a>
            <a href="https://linkedin.com/in/jaylon-malone"
               class="rounded-full border px-6 py-3 text-sm font-medium text-ink hairline"
               style="background: var(--color-bg-2);">LinkedIn</a>
          </div>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Base>
